\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{pourbaix}[2026/05/10 v1.0 Pourbaix diagrams with LuaLaTeX and pgfplots]

\RequirePackage{iftex}
\ifLuaTeX\else
  \PackageError{pourbaix}{This package requires LuaLaTeX}{Compile the document with LuaLaTeX.}
\fi

\RequirePackage{pgfplots}
\RequirePackage{pgfkeys}
\RequirePackage{xparse}
\RequirePackage{etoolbox}
\RequirePackage[version=4]{mhchem}

\pgfplotsset{compat=1.18}

% pgfplots extra ticks are current-axis options.
% Reset the Lua cache at the beginning of each axis so overlaid diagrams
% accumulate their ticks without leaking state to the next axis.
\AtBeginEnvironment{axis}{\directlua{require("pourbaix").tex_reset_axis_ticks()}}

\tikzset{
  pourbaix label/.style={
    font=\scriptsize,
    fill=white,
    fill opacity=.78,
    text opacity=1,
    inner sep=1.3pt,
    rounded corners=1pt
  },
  pourbaix frontier label/.style={
    fill=white,
    draw,
    circle,
    pos=.5,
    inner sep=1pt,
    font=\scriptsize
  },
  pourbaix water label/.style={
    font=\scriptsize,
    fill=white,
    inner sep=1pt
  }
}

\pgfplotsset{
  pourbaix axis/.style={
    xlabel={pH},
    ylabel={$E\,/\,\mathrm{V}$},
    xmin=0,
    xmax=14,
    grid=both,
    minor tick num=1,
    axis line style={black!60},
    tick style={black!60}
  }
}

