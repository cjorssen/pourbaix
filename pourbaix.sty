\NewDocumentCommand { \PourbaixDeclareElement } { O{} }
  {\begingroup
    \pgfkeys{/pourbaix/declareelement/.cd,symbol=,element=,id=,name=,metal=,Emin=,Emax=,#1}%
    \directlua{require("pourbaix").declare_element({
      symbol = "\luaescapestring{\pgfkeysvalueof{/pourbaix/declareelement/symbol}}",
      element = "\luaescapestring{\pgfkeysvalueof{/pourbaix/declareelement/element}}",
      id = "\luaescapestring{\pgfkeysvalueof{/pourbaix/declareelement/id}}",
      name = "\luaescapestring{\pgfkeysvalueof{/pourbaix/declareelement/name}}",
      metal = "\luaescapestring{\pgfkeysvalueof{/pourbaix/declareelement/metal}}",
      Emin = "\luaescapestring{\pgfkeysvalueof{/pourbaix/declareelement/Emin}}",
      Emax = "\luaescapestring{\pgfkeysvalueof{/pourbaix/declareelement/Emax}}"
    })}%
   \endgroup}

\NewDocumentCommand { \PourbaixAddSpecies } { O{} }
  {\begingroup
    \pgfkeys{/pourbaix/speciesdata/.cd,element=,id=,formula=,phase=aq,oxstate=,color=,nmetal=1,#1}%
    \directlua{require("pourbaix").add_species("\luaescapestring{\pgfkeysvalueof{/pourbaix/speciesdata/element}}",{
      id = "\luaescapestring{\pgfkeysvalueof{/pourbaix/speciesdata/id}}",
      formula = "\luaescapestring{\pgfkeysvalueof{/pourbaix/speciesdata/formula}}",
      phase = "\luaescapestring{\pgfkeysvalueof{/pourbaix/speciesdata/phase}}",
      oxState = "\luaescapestring{\pgfkeysvalueof{/pourbaix/speciesdata/oxstate}}",
      color = "\luaescapestring{\pgfkeysvalueof{/pourbaix/speciesdata/color}}",
      nMetal = "\luaescapestring{\pgfkeysvalueof{/pourbaix/speciesdata/nmetal}}"
    })}%
   \endgroup}

