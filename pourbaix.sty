\pgfkeys{
  /pourbaix/template/.is family,
  /pourbaix/template,
  element/.initial=,
  symbol/.initial=,
  name/.initial=,
  metal/.initial=,
  redox pairs/.initial=dominant,
  acid base/.initial=true,
  redox/.initial=true,
  comments/.initial=true,
  phase default/.initial=aq,
  check database/.initial=true
}

\NewDocumentCommand { \PourbaixAddTemplate } { O{} m }
  {\begingroup
    \pgfkeys{/pourbaix/template/.cd,element=,symbol=,name=,metal=,redox pairs=dominant,acid base=true,redox=true,comments=true,phase default=aq,check database=true,#1}%
    \directlua{require("pourbaix").tex_add_template({
      element = "\luaescapestring{\pgfkeysvalueof{/pourbaix/template/element}}",
      symbol = "\luaescapestring{\pgfkeysvalueof{/pourbaix/template/symbol}}",
      name = "\luaescapestring{\pgfkeysvalueof{/pourbaix/template/name}}",
      metal = "\luaescapestring{\pgfkeysvalueof{/pourbaix/template/metal}}",
      redox_pairs = "\luaescapestring{\pgfkeysvalueof{/pourbaix/template/redox pairs}}",
      acid_base = "\luaescapestring{\pgfkeysvalueof{/pourbaix/template/acid base}}",
      redox = "\luaescapestring{\pgfkeysvalueof{/pourbaix/template/redox}}",
      comments = "\luaescapestring{\pgfkeysvalueof{/pourbaix/template/comments}}",
      phase_default = "\luaescapestring{\pgfkeysvalueof{/pourbaix/template/phase default}}",
      check_database = "\luaescapestring{\pgfkeysvalueof{/pourbaix/template/check database}}",
      species = "\luaescapestring{#2}"
    })}%
   \endgroup}

\NewDocumentCommand { \PourbaixLoadData } { m }
  {\InputIfFileExists{#1}{}{\PackageError{pourbaix}{Data file not found: #1}{Check the file path.}}}

\NewDocumentCommand { \PourbaixLoadLuaData } { m }
  {\directlua{require("pourbaix").load_user_data("\luaescapestring{#1}")}}

\NewDocumentCommand { \PourbaixValidateElement } { m }
  {\directlua{require("pourbaix").tex_validate_element("\luaescapestring{#1}")}}

\NewDocumentCommand { \PourbaixShowElementData } { m }
  {\directlua{require("pourbaix").tex_show_element_data("\luaescapestring{#1}")}}

