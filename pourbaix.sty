% ---------------------------------------------------------------------------
% Declarative interface for extending the thermodynamic database.
% Public macros remain pgfkeys-based; Lua receives normalized tables
% compatible with pourbaix-data.lua.
% ---------------------------------------------------------------------------

\pgfkeys{
  /pourbaix/declareelement/.is family,
  /pourbaix/declareelement,
  symbol/.initial=,
  element/.initial=,
  id/.initial=,
  name/.initial=,
  metal/.initial=,
  Emin/.initial=,
  Emax/.initial=,
  E min/.code={\pgfkeyssetvalue{/pourbaix/declareelement/Emin}{#1}},
  E max/.code={\pgfkeyssetvalue{/pourbaix/declareelement/Emax}{#1}}
}

